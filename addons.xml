<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<addon id="plugin.video.stratos" name="FLIX PRIME PLUS beta1" version="3.7.0" provider-name="Stratos/Stock">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
        <import addon="script.module.beautifulsoup4"/>
        <import addon="script.module.resolveurl"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
            <screenshot>Screenshot1.png</screenshot>
            <screenshot>Screenshot2.png</screenshot>
            <screenshot>Screenshot3.png</screenshot>
        </assets>
        <summary lang="fr">Extension Vidéo FLIX PRIME PLUS beta1</summary>
        <description lang="fr">Tous les films, series et animes, SANS PUBS. Lien Telegram: t.me/flixprimeplus1</description>
    </extension>
</addon>

<addon id="repository.stratos" name="Stratos Repository" version="1.0.4" provider-name="Stratos">
    <extension point="xbmc.addon.repository" name="Stratos Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/equationstratos/flixprimeplustest/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/equationstratos/flixprimeplustest/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/equationstratos/flixprimeplustest/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Dépôt Officiel Stratos</summary>
        <description lang="fr">Dépot Officiel Stratos</description>
        <platform>all</platform>
        <assets>
            <icon>https://raw.githubusercontent.com/equationstratos/flixprimeplustest/main/repository.stratos/icon.png</icon>
            <fanart>https://raw.githubusercontent.com/equationstratos/flixprimeplustest/main/repository.stratos/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

</addons>
